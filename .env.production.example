# ============================================================
# SIG-PANTAU TSUNAMI - Production Environment Example
# Copy file ini menjadi .env di VPS, lalu ubah nilainya.
# ============================================================

# Domain publik tanpa https://
DOMAIN=sigtsunami.my.id

# Email untuk sertifikat SSL otomatis Let's Encrypt via Caddy
ACME_EMAIL=emailkamu@example.com

# URL publik aplikasi
PUBLIC_APP_URL=https://sigtsunami.my.id
PUBLIC_WS_URL=wss://sigtsunami.my.id

# Database PostGIS
POSTGRES_USER=tsunami
POSTGRES_PASSWORD=ganti_password_database_yang_kuat
POSTGRES_DB=sig_tsunami

# Backend FastAPI
DATABASE_URL=postgresql+asyncpg://tsunami:ganti_password_database_yang_kuat@db:5432/sig_tsunami
SECRET_KEY=ganti_dengan_secret_key_panjang_random
ENVIRONMENT=production

# Konfigurasi simulasi sensor
SENSOR_STREAM_INTERVAL_SEC=10
BASELINE_WINDOW_MIN=45
SMOOTHING_SAMPLES=5

# Konfigurasi sirene
SIREN_COOLDOWN_MIN=5
SIREN_NORMAL_STABLE_MIN=10